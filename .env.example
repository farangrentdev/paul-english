# SQLite — путь к файлу БД (в проде: на persistent volume, напр. /data/app.db)
DATABASE_URL="file:./dev.db"

# NextAuth — обязательно задать в проде (openssl rand -base64 32)
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# Базовый публичный URL приложения (используется в return_url ЮKassa, метаданных и т.п.)
APP_URL="http://localhost:3000"

# Домен и email для Let's Encrypt (используются Caddy в docker-compose)
DOMAIN="paul-english.ru"
LETSENCRYPT_EMAIL="admin@pavelenglish.ru"

# ЮKassa — shopId и секретный ключ из ЛК ЮKassa (опционально: без них демо-режим)
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""

# Первый администратор (создаётся при сидировании)
SEED_ADMIN_EMAIL="admin@pavelenglish.ru"
SEED_ADMIN_PASSWORD="change-me"
